# Contraseña de acceso a la app.
# Podés poner texto plano O un hash bcrypt generado con:
#   php -r "echo password_hash('mi_contraseña', PASSWORD_BCRYPT);"
APP_PASS=cambiar_por_tu_contraseña

# Ruta del archivo de datos, relativa a la raíz del proyecto
DATA_FILE=data/gastos.json

# Seguridad de sesión
SESSION_TTL=3600
MAX_ATTEMPTS=3
LOCKOUT_SEC=60

# Las personas se gestionan desde el menú Configuración dentro de la app.

# Clave de la API de Claude (Anthropic), para el reconocimiento automático
# de comprobantes (Smart Recognition / OCR). Se obtiene en console.anthropic.com
ANTHROPIC_API_KEY=
